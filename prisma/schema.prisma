generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum MaterialStatus {
  UPLOADED
  PROCESSING
  READY
  ERROR
}

enum StudyAssetType {
  STUDY_GUIDE
  PRACTICE_QUIZ
  FLASHCARDS
  CRAM_SHEET
}

model UserProfile {
  id            String           @id @default(cuid())
  email         String           @unique
  fullName      String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  subscription  Subscription?
  courses       Course[]
  materials     CourseMaterial[]
  analysisRuns  AnalysisRun[]
  studyAssets   StudyAsset[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(INACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 UserProfile        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id           String           @id @default(cuid())
  userId       String
  name         String
  code         String?
  term         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  owner        UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  materials    CourseMaterial[]
  topics       ExtractedTopic[]
  analysisRuns AnalysisRun[]
  studyAssets  StudyAsset[]

  @@index([userId, createdAt])
}

model CourseMaterial {
  id            String         @id @default(cuid())
  courseId       String
  userId         String
  fileName       String
  mimeType       String
  sizeBytes      Int
  storagePath    String?
  extractedText  String?
  extractionNote String?
  status         MaterialStatus @default(UPLOADED)
  errorMessage   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  processedAt    DateTime?
  course         Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user           UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics         ExtractedTopic[]

  @@index([courseId, createdAt])
  @@index([userId, createdAt])
}

model ExtractedTopic {
  id              String         @id @default(cuid())
  courseId         String
  materialId       String?
  title            String
  summary          String
  keyPhrases       String[]
  occurrenceCount  Int            @default(0)
  evidenceCount    Int            @default(0)
  emphasisScore    Float          @default(0)
  confidence       Float          @default(0)
  reasons          String[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  material         CourseMaterial? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([courseId, emphasisScore])
}

model AnalysisRun {
  id                String       @id @default(cuid())
  courseId           String
  userId             String
  modelName          String
  sourceMaterialIds  String[]
  totalTopics        Int
  rankedTopics       Json
  processingNotes    String?
  createdAt          DateTime    @default(now())
  course             Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user               UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([courseId, createdAt])
}

model StudyAsset {
  id         String        @id @default(cuid())
  courseId    String
  userId      String
  type        StudyAssetType
  title       String
  payload     Json
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  course      Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, type])
  @@index([courseId, createdAt])
}
